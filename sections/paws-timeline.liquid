{% comment %} Paws & Co. Timeline — horizontal journey with yellow dots {% endcomment %}
<section class="paws-timeline">
  <div class="paws-wrap">
    <div class="paws-section-head paws-reveal-up" style="justify-content: center; text-align: center;">
      <div>
        {% if section.settings.eyebrow != blank %}
          <span class="paws-eyebrow" style="color: var(--paws-yellow);"><span>{{ section.settings.eyebrow_icon }}</span> {{ section.settings.eyebrow }}</span>
        {% endif %}
        <h2>{{ section.settings.heading }}</h2>
      </div>
    </div>

    <div class="paws-timeline-track">
      {% for block in section.blocks %}
        <div class="paws-timeline-item paws-reveal-up{% if forloop.index0 > 0 %} delay-{{ forloop.index0 }}{% endif %}" {{ block.shopify_attributes }}>
          <div class="paws-timeline-dot">{{ block.settings.marker }}</div>
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.body }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Paws Timeline",
  "tag": "section",
  "class": "paws-section-timeline",
  "settings": [
    { "type": "text", "id": "eyebrow_icon", "label": "Eyebrow emoji", "default": "📅" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow label", "default": "the paws journey" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>From kitchen to<br>kennels everywhere</p>" }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Milestone",
      "limit": 10,
      "settings": [
        { "type": "text", "id": "marker", "label": "Dot label (e.g. '14)", "default": "'14" },
        { "type": "text", "id": "title", "label": "Title", "default": "Biscuit says yes" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "First batch of Salmon Crunchies. Founder's kitchen." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Paws Timeline",
      "blocks": [
        { "type": "milestone", "settings": { "marker": "'14", "title": "Biscuit says yes", "body": "First batch of Salmon Crunchies. Founder's kitchen." } },
        { "type": "milestone", "settings": { "marker": "'18", "title": "First shop opens", "body": "Tiny brick-and-mortar in Portland. Still standing." } },
        { "type": "milestone", "settings": { "marker": "'22", "title": "Online pack grows", "body": "50k+ subscribers, vet partnership, new HQ." } },
        { "type": "milestone", "settings": { "marker": "'26", "title": "340 products & counting", "body": "Here, now, shipping tail-wags everywhere." } }
      ]
    }
  ]
}
{% endschema %}
