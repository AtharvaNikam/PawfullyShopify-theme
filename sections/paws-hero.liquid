{% comment %} Paws & Co. Hero Slider — 3 editable slides {% endcomment %}
{%- if section.blocks.size == 0 -%}
  {%- if request.design_mode -%}
    <section class="paws-hero-section paws-hero-empty">
      <div class="paws-wrap" style="padding-block: 4rem; text-align: center;">
        <p style="font-family: var(--paws-font-head); font-weight: 700;">Add a slide block in the theme editor to show the hero.</p>
      </div>
    </section>
  {%- endif -%}
{%- else -%}
<section class="paws-hero-section">
  <div class="paws-slider">
    {% for block in section.blocks %}
      <div
        class="paws-slide paws-slide--{{ block.settings.bg_color }}{% if forloop.first %} active{% endif %}"
        aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
        {{ block.shopify_attributes }}
      >
        <div class="paws-slide-content">
          {% if block.settings.tag != blank %}
            <span class="paws-slide-tag"><span class="paws-dot-inline"></span>{{ block.settings.tag }}</span>
          {% endif %}
          <h1>{{ block.settings.heading }}</h1>
          {% if block.settings.subtext != blank %}
            <p>{{ block.settings.subtext }}</p>
          {% endif %}
          <div class="paws-slide-ctas">
            {% if block.settings.primary_label != blank %}
              <a href="{{ block.settings.primary_link | default: '#' }}" class="paws-btn paws-btn--coral paws-btn--lg">
                {{ block.settings.primary_label }}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            {% endif %}
            {% if block.settings.secondary_label != blank %}
              <a href="{{ block.settings.secondary_link | default: '#' }}" class="paws-btn paws-btn--white paws-btn--lg">
                {{ block.settings.secondary_label }}
              </a>
            {% endif %}
          </div>
        </div>
        <div class="paws-slide-visual">
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: block.settings.image.alt | default: block.settings.heading }}
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  {% if section.settings.show_sticker %}
    <div class="paws-hero-sticker">
      <svg viewBox="0 0 140 140">
        <defs>
          <path id="circ-{{ section.id }}" d="M70,70 m-52,0 a52,52 0 1,1 104,0 a52,52 0 1,1 -104,0"/>
        </defs>
        <text fill="#FFF8E7" font-family="Bagel Fat One, cursive" font-size="13" letter-spacing="3">
          <textPath href="#circ-{{ section.id }}">{{ section.settings.sticker_text }}</textPath>
        </text>
        <g transform="translate(70 70)">
          <circle r="22" fill="#FFD84D" stroke="#1A1A1A" stroke-width="3"/>
          <g fill="#1A1A1A" transform="translate(-9 -9) scale(0.75)">
            <circle cx="4" cy="10" r="2.5"/><circle cx="20" cy="10" r="2.5"/>
            <circle cx="8" cy="4" r="2"/><circle cx="16" cy="4" r="2"/>
            <path d="M12 11c-3 0-5 2.3-5 4.5 0 1.7 1.2 3 3 3 .8 0 1.4-.3 2-.7.6.4 1.2.7 2 .7 1.8 0 3-1.3 3-3 0-2.2-2-4.5-5-4.5z"/>
          </g>
        </g>
      </svg>
    </div>
  {% endif %}

  {% if section.blocks.size > 1 %}
    <div class="paws-slider-nav">
      <button class="paws-slider-prev" aria-label="Previous slide">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <div class="paws-slider-dots">
        {% for block in section.blocks %}
          <button class="paws-dot{% if forloop.first %} active{% endif %}" data-slide="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
        {% endfor %}
      </div>
      <button class="paws-slider-next" aria-label="Next slide">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
  {% endif %}
</section>
{%- endif -%}

{% schema %}
{
  "name": "Paws Hero Slider",
  "tag": "section",
  "class": "paws-section-hero",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_sticker",
      "label": "Show rotating sticker badge",
      "default": true
    },
    {
      "type": "text",
      "id": "sticker_text",
      "label": "Sticker text (circular)",
      "default": "MADE WITH LOVE ★ TAIL TESTED ★ "
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 5,
      "settings": [
        {
          "type": "select",
          "id": "bg_color",
          "label": "Background color",
          "options": [
            { "value": "yellow", "label": "Yellow" },
            { "value": "sky", "label": "Sky Blue" },
            { "value": "mint", "label": "Mint" },
            { "value": "pink", "label": "Pink" }
          ],
          "default": "yellow"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag label",
          "default": "New arrivals · Spring '26"
        },
        {
          "type": "richtext",
          "id": "heading",
          "label": "Heading (use <em> for emphasis)",
          "default": "<p>Spoil your<br><em>good boy</em> silly.</p>"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "Small-batch treats, snuggly beds, and toys so fun they'll wag themselves into a tizzy."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide image"
        },
        {
          "type": "text",
          "id": "primary_label",
          "label": "Primary button label",
          "default": "Shop the goodies"
        },
        {
          "type": "url",
          "id": "primary_link",
          "label": "Primary button link"
        },
        {
          "type": "text",
          "id": "secondary_label",
          "label": "Secondary button label",
          "default": "Our story"
        },
        {
          "type": "url",
          "id": "secondary_link",
          "label": "Secondary button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Paws Hero Slider",
      "blocks": [
        { "type": "slide", "settings": { "bg_color": "yellow" } },
        { "type": "slide", "settings": { "bg_color": "sky" } },
        { "type": "slide", "settings": { "bg_color": "mint" } }
      ]
    }
  ]
}
{% endschema %}
