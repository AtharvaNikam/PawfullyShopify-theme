{% comment %} Paws & Co. Page Header (yellow hero) for inner pages {% endcomment %}
<section class="paws-page-header">
  <div class="paws-wrap">
    {% if section.settings.show_breadcrumb %}
      <div class="paws-breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="m9 18 6-6-6-6"/></svg>
        <span>{{ section.settings.current_label | default: page.title }}</span>
      </div>
    {% endif %}
    <h1>{{ section.settings.heading }}</h1>
    {% if section.settings.subtext != blank %}
      <p>{{ section.settings.subtext }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Paws Page Header",
  "tag": "section",
  "class": "paws-section-page-header",
  "settings": [
    { "type": "checkbox", "id": "show_breadcrumb", "label": "Show breadcrumb", "default": true },
    { "type": "text", "id": "current_label", "label": "Current page label (breadcrumb)" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Page title</p>" },
    { "type": "textarea", "id": "subtext", "label": "Subtext" }
  ],
  "presets": [
    { "name": "Paws Page Header" }
  ]
}
{% endschema %}
