{% comment %} Paws & Co. Sticky Header — logo + nav + actions + custom cart drawer {% endcomment %}

<header class="paws-header">
  <div class="paws-header-inner">
    <button class="paws-icon-btn paws-mobile-menu-toggle" aria-label="Open menu" type="button" data-paws-mobile-menu-open>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" width="20" height="20"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    </button>

    <a href="{{ routes.root_url }}" class="paws-logo">
      <span class="paws-logo-badge">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><circle cx="5" cy="9" r="2.2"/><circle cx="19" cy="9" r="2.2"/><circle cx="9" cy="5" r="2"/><circle cx="15" cy="5" r="2"/><path d="M12 11c-3.5 0-6 2.8-6 5.5 0 2 1.5 3.5 3.5 3.5 1 0 1.8-.4 2.5-.9.7.5 1.5.9 2.5.9 2 0 3.5-1.5 3.5-3.5 0-2.7-2.5-5.5-6-5.5z"/></svg>
      </span>
      {{ section.settings.brand_name | default: shop.name }}
    </a>

    <nav class="paws-nav">
      {%- assign menu_linklist = section.settings.menu -%}
      {%- if menu_linklist != blank and linklists[menu_linklist].links.size > 0 -%}
        {%- for link in linklists[menu_linklist].links -%}
          <a href="{{ link.url }}"{% if link.active %} class="active"{% endif %}>{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="{{ routes.root_url }}"{% if request.page_type == 'index' %} class="active"{% endif %}>Home</a>
        <a href="{{ routes.all_products_collection_url }}"{% if request.page_type == 'collection' %} class="active"{% endif %}>Shop</a>
        <a href="/pages/about"{% if request.path contains '/pages/about' %} class="active"{% endif %}>About</a>
        <a href="/pages/contact"{% if request.path contains '/pages/contact' %} class="active"{% endif %}>Contact</a>
      {%- endif -%}
    </nav>

    <div class="paws-header-actions">
      <a href="{{ routes.search_url }}" class="paws-icon-btn" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" width="20" height="20"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      </a>
      <a href="{{ routes.account_url }}" class="paws-icon-btn" aria-label="Account">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <button class="paws-icon-btn" type="button" data-paws-cart-open aria-label="Open cart" aria-haspopup="dialog">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="paws-cart-count"{% if cart.item_count == 0 %} style="display:none"{% endif %} data-cart-count>{{ cart.item_count }}</span>
      </button>
    </div>
  </div>
</header>

{% comment %} Mobile drawer menu — slides in from right {% endcomment %}
<div class="paws-mobile-menu" data-paws-mobile-menu aria-hidden="true">
  <div class="paws-mobile-nav">
    <button class="paws-mobile-menu-close" aria-label="Close menu" type="button" data-paws-mobile-menu-close>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" width="24" height="24"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
    {%- if menu_linklist != blank and linklists[menu_linklist].links.size > 0 -%}
      {%- for link in linklists[menu_linklist].links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
    {%- else -%}
      <a href="{{ routes.root_url }}">Home</a>
      <a href="{{ routes.all_products_collection_url }}">Shop</a>
      <a href="/pages/about">About</a>
      <a href="/pages/contact">Contact</a>
    {%- endif -%}
  </div>
</div>

{% comment %} Paws Cart Drawer — simple custom drawer (no <dialog>, no Horizon custom element) {% endcomment %}
<div class="paws-cart-overlay" data-paws-cart-close aria-hidden="true"></div>
<aside class="paws-cart-drawer" data-paws-cart aria-hidden="true" aria-label="Shopping cart">
  <div class="paws-cart-head">
    <h3>Your Cart <span class="paws-cart-head-count">({{ cart.item_count }})</span></h3>
    <button class="paws-icon-btn" type="button" data-paws-cart-close aria-label="Close cart">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" width="20" height="20"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <div class="paws-cart-body" data-paws-cart-body>
    {%- if cart.item_count == 0 -%}
      <div class="paws-cart-empty" style="padding: 3rem 1rem; text-align: center;">
        <span style="font-size: 3rem; display: block; margin-bottom: 1rem;">🐾</span>
        <p style="font-family: var(--paws-font-head); font-weight: 700; margin-bottom: 1.5rem;">Your cart's empty</p>
        <a href="{{ routes.all_products_collection_url }}" class="paws-btn paws-btn--coral">Start shopping</a>
      </div>
    {%- else -%}
      {%- assign free_shipping_threshold = section.settings.free_shipping_threshold | times: 100 -%}
      {%- if free_shipping_threshold > 0 -%}
        {%- assign remaining = free_shipping_threshold | minus: cart.total_price -%}
        <div class="paws-shipping-bar">
          {%- if remaining > 0 -%}
            Add {{ remaining | money }} more for free shipping! 🎉
          {%- else -%}
            ✓ You've unlocked free shipping!
          {%- endif -%}
          <div class="paws-progress-bar">
            {%- assign progress = cart.total_price | times: 100 | divided_by: free_shipping_threshold -%}
            {%- if progress > 100 -%}{%- assign progress = 100 -%}{%- endif -%}
            <div class="paws-progress-fill" style="width: {{ progress }}%;"></div>
          </div>
        </div>
      {%- endif -%}

      {%- for item in cart.items -%}
        <div class="paws-cart-item" data-cart-line="{{ forloop.index }}" data-cart-key="{{ item.key }}">
          {%- if item.image -%}
            <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.product.title | escape }}" loading="lazy">
          {%- endif -%}
          <div class="paws-cart-item-info">
            <h4>{{ item.product.title }}</h4>
            {%- unless item.variant.title contains 'Default' -%}
              <span class="paws-cart-item-meta">{{ item.variant.title }}</span>
            {%- endunless -%}
            <div class="paws-qty-control">
              <button type="button" data-paws-qty="minus" data-line="{{ forloop.index }}" aria-label="Decrease">−</button>
              <span data-paws-qty-value>{{ item.quantity }}</span>
              <button type="button" data-paws-qty="plus" data-line="{{ forloop.index }}" aria-label="Increase">+</button>
            </div>
          </div>
          <div class="paws-cart-item-right">
            <span class="paws-price">{{ item.final_line_price | money }}</span>
            <button class="paws-remove-btn" type="button" data-paws-cart-remove data-line="{{ forloop.index }}">remove</button>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- if cart.item_count > 0 -%}
    <div class="paws-cart-foot">
      <div class="paws-cart-total">
        <span>Subtotal</span>
        <span class="paws-total-price" data-cart-total>{{ cart.total_price | money }}</span>
      </div>
      <a href="{{ routes.cart_url }}" class="paws-btn paws-btn--ink paws-btn--sm" style="display: block; text-align: center; margin-bottom: 0.75rem;">View cart</a>
      <a href="/checkout" class="paws-btn paws-btn--coral paws-btn--lg paws-checkout-btn" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
        Checkout
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  {%- endif -%}
</aside>

<script>
  (function () {
    // ── Calibrate header height for sticky offsets ─────────────
    function calibrate() {
      var header = document.querySelector('.paws-header');
      var group = document.getElementById('header-group');
      if (!header) return;
      document.body.style.setProperty('--header-height', header.offsetHeight + 'px');
      if (group) document.body.style.setProperty('--header-group-height', group.offsetHeight + 'px');
      document.body.style.setProperty('--top-row-height', header.offsetHeight + 'px');
    }
    calibrate();
    window.addEventListener('load', calibrate);
    window.addEventListener('resize', calibrate);

    // ── Mobile drawer menu ─────────────────────────────────────
    var menu = document.querySelector('[data-paws-mobile-menu]');
    var openMenuBtn = document.querySelector('[data-paws-mobile-menu-open]');
    document.querySelectorAll('[data-paws-mobile-menu-close]').forEach(function (b) {
      b.addEventListener('click', function () { if (menu) { menu.classList.remove('open'); menu.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; } });
    });
    if (openMenuBtn && menu) {
      openMenuBtn.addEventListener('click', function () {
        menu.classList.add('open');
        menu.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      });
      menu.addEventListener('click', function (e) {
        if (e.target === menu) {
          menu.classList.remove('open');
          menu.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        }
      });
    }
    document.addEventListener('keydown', function (e) {
      if (e.key !== 'Escape') return;
      if (menu && menu.classList.contains('open')) {
        menu.classList.remove('open');
        menu.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Paws Header",
  "tag": "section",
  "class": "paws-section-header",
  "settings": [
    { "type": "text", "id": "brand_name", "label": "Brand name", "default": "paws & co." },
    { "type": "link_list", "id": "menu", "label": "Navigation menu" },
    { "type": "header", "content": "Cart drawer" },
    { "type": "number", "id": "free_shipping_threshold", "label": "Free shipping threshold (in store currency)", "default": 50, "info": "Cart progress bar targets this value. Set 0 to hide." }
  ],
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
