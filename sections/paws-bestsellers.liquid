{% comment %}
  Paws & Co. Bestsellers
  ──────────────────────
  Filter pills now pick COLLECTIONS, not tags/types. Each pill block has its own
  collection picker. Clicking a pill shows products from that collection.

  "All" pill shows the main section collection. Each additional pill is a
  standalone collection tab.
{% endcomment %}

{%- assign main_collection = section.settings.collection -%}
{%- assign max_products = section.settings.product_count | default: 8 -%}

<section class="paws-bestsellers" id="section-{{ section.id }}">
  <div class="paws-wrap">
    <div class="paws-section-head">
      <div>
        {% if section.settings.eyebrow != blank %}
          <span class="paws-eyebrow"><span>{{ section.settings.eyebrow_icon }}</span> {{ section.settings.eyebrow }}</span>
        {% endif %}
        <h2>{{ section.settings.heading }}</h2>
      </div>
      {% if section.settings.link_label != blank %}
        <a href="{{ section.settings.link_url | default: main_collection.url | default: '/collections/all' }}" class="paws-btn paws-btn--ink paws-btn--sm">{{ section.settings.link_label }} →</a>
      {% endif %}
    </div>

    {% if section.settings.show_filters and section.blocks.size > 0 %}
      <div class="paws-filter-bar">
        {% if section.settings.show_all_pill %}
          <button class="paws-filter-pill active" type="button" data-paws-filter="__all__">
            {{ section.settings.all_pill_label | default: 'Everything' }}
          </button>
        {% endif %}
        {% for block in section.blocks %}
          {%- if block.type == 'filter' -%}
            {%- assign block_collection = block.settings.collection -%}
            {%- if block_collection != blank -%}
              <button
                class="paws-filter-pill{% unless section.settings.show_all_pill %}{% if forloop.first %} active{% endif %}{% endunless %}"
                type="button"
                data-paws-filter="{{ block_collection.handle }}"
                {{ block.shopify_attributes }}
              >{{ block.settings.label | default: block_collection.title }}</button>
            {%- endif -%}
          {%- endif -%}
        {% endfor %}
      </div>
    {% endif %}

    {% comment %} Wrapper for filterable panels — each panel is one collection's product grid {% endcomment %}
    <div class="paws-bestsellers-panels">
      {% if section.settings.show_all_pill %}
        {% render 'paws-product-panel',
           panel_key: '__all__',
           panel_collection: main_collection,
           max_products: max_products,
           is_active: true %}
      {% endif %}

      {%- assign first_panel_shown = section.settings.show_all_pill -%}
      {% for block in section.blocks %}
        {%- if block.type == 'filter' and block.settings.collection != blank -%}
          {% render 'paws-product-panel',
             panel_key: block.settings.collection.handle,
             panel_collection: block.settings.collection,
             max_products: max_products,
             is_active: first_panel_shown == false %}
          {%- assign first_panel_shown = true -%}
        {%- endif -%}
      {% endfor %}

      {% if section.blocks.size == 0 or section.settings.show_filters == false %}
        {% render 'paws-product-panel',
           panel_key: '__main__',
           panel_collection: main_collection,
           max_products: max_products,
           is_active: true %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Paws Bestsellers",
  "tag": "section",
  "class": "paws-section-bestsellers",
  "settings": [
    { "type": "header", "content": "Section heading" },
    { "type": "text", "id": "eyebrow_icon", "label": "Eyebrow emoji", "default": "⭐" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow label", "default": "top dogs (and cats)" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>The crowd pleasers</p>" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop all" },
    { "type": "url", "id": "link_url", "label": "Link URL (defaults to main collection)" },
    { "type": "header", "content": "Products" },
    { "type": "collection", "id": "collection", "label": "Default / 'All' collection", "info": "Shown when 'Everything' pill is active, or when filters are disabled." },
    { "type": "range", "id": "product_count", "label": "Products per tab", "min": 4, "max": 16, "step": 2, "default": 8 },
    { "type": "header", "content": "Filter pills" },
    { "type": "checkbox", "id": "show_filters", "label": "Show filter pills", "default": true },
    { "type": "checkbox", "id": "show_all_pill", "label": "Show 'Everything' pill first", "default": true },
    { "type": "text", "id": "all_pill_label", "label": "'Everything' pill label", "default": "Everything" }
  ],
  "blocks": [
    {
      "type": "filter",
      "name": "Collection tab",
      "limit": 10,
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection to show" },
        { "type": "text", "id": "label", "label": "Pill label (defaults to collection title)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Paws Bestsellers",
      "blocks": [
        { "type": "filter" },
        { "type": "filter" },
        { "type": "filter" },
        { "type": "filter" }
      ]
    }
  ]
}
{% endschema %}
