{% comment %} Paws & Co. Newsletter — mint background pill form {% endcomment %}
<section class="paws-newsletter">
  <div class="paws-wrap">
    {% if section.settings.eyebrow != blank %}
      <span class="paws-eyebrow"><span>{{ section.settings.eyebrow_icon }}</span> {{ section.settings.eyebrow }}</span>
    {% endif %}
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.subtext != blank %}
      <p>{{ section.settings.subtext }}</p>
    {% endif %}

    {% form 'customer', class: 'paws-newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input
        type="email"
        name="contact[email]"
        placeholder="{{ section.settings.input_placeholder }}"
        required
        aria-label="Email"
      >
      <button type="submit"><span>{{ section.settings.button_label }}</span></button>
      {% if form.posted_successfully? %}
        <p style="margin-top: 1rem; color: var(--paws-mint-dark); font-weight: 700;">✓ Thanks! Check your inbox.</p>
      {% endif %}
      {% if form.errors %}
        <p style="margin-top: 1rem; color: var(--paws-coral); font-weight: 700;">{{ form.errors | default_errors }}</p>
      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Paws Newsletter",
  "tag": "section",
  "class": "paws-section-newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow_icon", "label": "Eyebrow emoji", "default": "💌" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow label", "default": "join the pack" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get 20% off your first order" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Plus sneak peeks, new drops, and tail-wagging tips. No spam, just good boys." },
    { "type": "text", "id": "input_placeholder", "label": "Input placeholder", "default": "your@email.com" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Sign me up!" }
  ],
  "presets": [
    { "name": "Paws Newsletter" }
  ]
}
{% endschema %}
