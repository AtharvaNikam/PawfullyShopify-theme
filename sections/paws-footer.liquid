{% comment %} Paws & Co. Footer — 5-column dark footer {% endcomment %}
<footer class="paws-footer">
  <div class="paws-wrap">
    <div class="paws-footer-grid">
      <div class="paws-footer-brand">
        <a href="{{ routes.root_url }}" class="paws-logo">
          <span class="paws-logo-badge">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><circle cx="5" cy="9" r="2.2"/><circle cx="19" cy="9" r="2.2"/><circle cx="9" cy="5" r="2"/><circle cx="15" cy="5" r="2"/><path d="M12 11c-3.5 0-6 2.8-6 5.5 0 2 1.5 3.5 3.5 3.5 1 0 1.8-.4 2.5-.9.7.5 1.5.9 2.5.9 2 0 3.5-1.5 3.5-3.5 0-2.7-2.5-5.5-6-5.5z"/></svg>
          </span>
          {{ section.settings.brand_name | default: shop.name }}
        </a>
        {% if section.settings.brand_tagline != blank %}
          <p>{{ section.settings.brand_tagline }}</p>
        {% endif %}

        <div class="paws-socials">
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" class="paws-social-link" aria-label="Instagram" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
            </a>
          {% endif %}
          {% if section.settings.tiktok_url != blank %}
            <a href="{{ section.settings.tiktok_url }}" class="paws-social-link" aria-label="TikTok" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M19 8.5a6.5 6.5 0 0 1-4-1.5v7.5a5.5 5.5 0 1 1-5.5-5.5v3a2.5 2.5 0 1 0 2.5 2.5V2h3a4 4 0 0 0 4 4v2.5z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.facebook_url != blank %}
            <a href="{{ section.settings.facebook_url }}" class="paws-social-link" aria-label="Facebook" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H8v-3h2.4V9.4c0-2.4 1.4-3.7 3.6-3.7 1 0 2.1.2 2.1.2v2.3h-1.2c-1.2 0-1.5.7-1.5 1.5V12h2.6l-.4 3h-2.2v7A10 10 0 0 0 22 12z"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      {% for block in section.blocks %}
        <div class="paws-footer-col" {{ block.shopify_attributes }}>
          <h4>{{ block.settings.heading }}</h4>
          {%- assign link_list = block.settings.link_list -%}
          {%- if link_list != blank and linklists[link_list].links.size > 0 -%}
            <ul>
              {% for link in linklists[link_list].links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          {%- else -%}
            <ul>
              {% if block.settings.link_1_label != blank %}<li><a href="{{ block.settings.link_1_url | default: '#' }}">{{ block.settings.link_1_label }}</a></li>{% endif %}
              {% if block.settings.link_2_label != blank %}<li><a href="{{ block.settings.link_2_url | default: '#' }}">{{ block.settings.link_2_label }}</a></li>{% endif %}
              {% if block.settings.link_3_label != blank %}<li><a href="{{ block.settings.link_3_url | default: '#' }}">{{ block.settings.link_3_label }}</a></li>{% endif %}
              {% if block.settings.link_4_label != blank %}<li><a href="{{ block.settings.link_4_url | default: '#' }}">{{ block.settings.link_4_label }}</a></li>{% endif %}
              {% if block.settings.link_5_label != blank %}<li><a href="{{ block.settings.link_5_url | default: '#' }}">{{ block.settings.link_5_label }}</a></li>{% endif %}
            </ul>
          {%- endif -%}
        </div>
      {% endfor %}
    </div>

    <div class="paws-footer-bottom">
      <span>{{ section.settings.copyright | replace: '{year}', 'now' | date: '%Y' }}</span>
      <div style="display: flex; gap: 1.5rem;">
        {% if section.settings.privacy_url != blank %}<a href="{{ section.settings.privacy_url }}">Privacy</a>{% endif %}
        {% if section.settings.terms_url != blank %}<a href="{{ section.settings.terms_url }}">Terms</a>{% endif %}
        {% if section.settings.accessibility_url != blank %}<a href="{{ section.settings.accessibility_url }}">Accessibility</a>{% endif %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Paws Footer",
  "tag": "section",
  "class": "paws-section-footer",
  "settings": [
    { "type": "header", "content": "Brand" },
    { "type": "text", "id": "brand_name", "label": "Brand name", "default": "paws & co." },
    { "type": "textarea", "id": "brand_tagline", "label": "Tagline", "default": "Tail-wagging goodies for the world's goodest boys and most exquisite cats. Small batch, big love." },
    { "type": "header", "content": "Socials" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok URL" },
    { "type": "url", "id": "facebook_url", "label": "Facebook URL" },
    { "type": "header", "content": "Legal" },
    { "type": "text", "id": "copyright", "label": "Copyright text", "default": "© {year} Paws & Co. Made with 🐾 in Portland." },
    { "type": "url", "id": "privacy_url", "label": "Privacy link" },
    { "type": "url", "id": "terms_url", "label": "Terms link" },
    { "type": "url", "id": "accessibility_url", "label": "Accessibility link" }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Footer column",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "heading", "label": "Column heading", "default": "Shop" },
        { "type": "link_list", "id": "link_list", "label": "Menu (overrides manual links)" },
        { "type": "header", "content": "Manual links (fallback)" },
        { "type": "text", "id": "link_1_label", "label": "Link 1 label", "default": "Food & Treats" },
        { "type": "url", "id": "link_1_url", "label": "Link 1 URL" },
        { "type": "text", "id": "link_2_label", "label": "Link 2 label", "default": "Toys" },
        { "type": "url", "id": "link_2_url", "label": "Link 2 URL" },
        { "type": "text", "id": "link_3_label", "label": "Link 3 label", "default": "Beds" },
        { "type": "url", "id": "link_3_url", "label": "Link 3 URL" },
        { "type": "text", "id": "link_4_label", "label": "Link 4 label" },
        { "type": "url", "id": "link_4_url", "label": "Link 4 URL" },
        { "type": "text", "id": "link_5_label", "label": "Link 5 label" },
        { "type": "url", "id": "link_5_url", "label": "Link 5 URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Paws Footer",
      "blocks": [
        { "type": "column", "settings": { "heading": "Shop", "link_1_label": "Food & Treats", "link_2_label": "Toys", "link_3_label": "Beds", "link_4_label": "Grooming" } },
        { "type": "column", "settings": { "heading": "Help", "link_1_label": "Contact", "link_2_label": "Shipping", "link_3_label": "Returns", "link_4_label": "FAQ" } },
        { "type": "column", "settings": { "heading": "Company", "link_1_label": "About", "link_2_label": "Careers", "link_3_label": "Press" } },
        { "type": "column", "settings": { "heading": "Pack Perks", "link_1_label": "Rewards", "link_2_label": "Gift Cards", "link_3_label": "Refer a Friend" } }
      ]
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}
