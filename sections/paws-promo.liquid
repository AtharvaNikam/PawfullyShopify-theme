{% comment %} Paws & Co. Promo Banner — pink background with rotating sticker {% endcomment %}
<section class="paws-promo" id="{{ section.settings.anchor | default: section.id }}">
  <div class="paws-wrap">
    <div class="paws-promo-inner">
      <div class="paws-reveal-up">
        {% if section.settings.eyebrow != blank %}
          <span class="paws-eyebrow" style="color: var(--paws-yellow);"><span>{{ section.settings.eyebrow_icon }}</span> {{ section.settings.eyebrow }}</span>
        {% endif %}
        <h2>{{ section.settings.heading }}</h2>
        {% if section.settings.subtext != blank %}
          <p>{{ section.settings.subtext }}</p>
        {% endif %}
        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link | default: '#' }}" class="paws-btn paws-btn--ink paws-btn--lg">
            {{ section.settings.button_label }}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        {% endif %}
      </div>
      <div class="paws-promo-visual paws-reveal-up delay-2">
        {% if section.settings.sticker_text != blank %}
          <span class="paws-promo-sticker">{{ section.settings.sticker_text }}</span>
        {% endif %}
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: section.settings.heading }}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Paws Promo Banner",
  "tag": "section",
  "class": "paws-section-promo",
  "settings": [
    { "type": "text", "id": "anchor", "label": "Anchor ID", "default": "how" },
    { "type": "text", "id": "eyebrow_icon", "label": "Eyebrow emoji", "default": "📦" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow label", "default": "the paws box" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>A monthly box built<br>just for them.</p>" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Take our 2-minute quiz. We'll assemble a box of treats, toys, and goodies tailored to their size, allergies, and personality. Love it or return it free." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Take the quiz" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "image_picker", "id": "image", "label": "Promo image" },
    { "type": "html", "id": "sticker_text", "label": "Sticker text (use <br>)", "default": "SAVE<br>15%" }
  ],
  "presets": [
    { "name": "Paws Promo Banner" }
  ]
}
{% endschema %}
