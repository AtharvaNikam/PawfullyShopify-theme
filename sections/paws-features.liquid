{% comment %} Paws & Co. Feature Strip — 4 feature blocks on ink background {% endcomment %}
<section class="paws-features">
  <div class="paws-wrap">
    <div class="paws-features-grid">
      {% for block in section.blocks %}
        <div class="paws-feature paws-reveal-up{% if forloop.index0 > 0 %} delay-{{ forloop.index0 }}{% endif %}" {{ block.shopify_attributes }}>
          <span class="paws-feature-icon paws-feature-icon--{{ block.settings.icon_color }}">
            {% case block.settings.icon %}
              {% when 'truck' %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><rect x="2" y="7" width="20" height="10" rx="2"/><path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2"/></svg>
              {% when 'heart' %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              {% when 'check' %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
              {% when 'clock' %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0z"/><path d="M12 7v5l3 3"/></svg>
              {% when 'star' %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {% else %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><circle cx="12" cy="12" r="9"/></svg>
            {% endcase %}
          </span>
          <div>
            <h4>{{ block.settings.heading }}</h4>
            <p>{{ block.settings.subtext }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Paws Features Strip",
  "tag": "section",
  "class": "paws-section-features",
  "settings": [],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck (shipping)" },
            { "value": "heart", "label": "Heart" },
            { "value": "check", "label": "Checkmark" },
            { "value": "clock", "label": "Clock" },
            { "value": "star", "label": "Star" }
          ],
          "default": "truck"
        },
        {
          "type": "select",
          "id": "icon_color",
          "label": "Icon background color",
          "options": [
            { "value": "yellow", "label": "Yellow" },
            { "value": "coral", "label": "Coral" },
            { "value": "sky", "label": "Sky" },
            { "value": "mint", "label": "Mint" },
            { "value": "pink", "label": "Pink" }
          ],
          "default": "yellow"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Feature heading",
          "default": "Free shipping"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Feature subtext",
          "default": "On all orders over $50"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Paws Features Strip",
      "blocks": [
        { "type": "feature", "settings": { "icon": "truck", "icon_color": "yellow", "heading": "Free shipping", "subtext": "On all orders over $50" } },
        { "type": "feature", "settings": { "icon": "heart", "icon_color": "coral", "heading": "Cruelty-free", "subtext": "Always, always, always" } },
        { "type": "feature", "settings": { "icon": "check", "icon_color": "mint", "heading": "Vet approved", "subtext": "Every single product" } },
        { "type": "feature", "settings": { "icon": "clock", "icon_color": "sky", "heading": "30-day returns", "subtext": "No fuss, full refund" } }
      ]
    }
  ]
}
{% endschema %}
