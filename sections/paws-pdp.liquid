{% comment %}
  Paws & Co. PDP — FULLY DYNAMIC FROM PRODUCT DATA
  ────────────────────────────────────────────────
  Every piece of content pulls from the product itself. The only thing merchants
  configure in the template editor is the SITE-WIDE perks strip (Free shipping,
  Cruelty-free, etc. — these apply to every product).

  PER-PRODUCT CONTENT COMES FROM:
  • product.title, product.description, product.type, product.vendor
  • product.media (all images)
  • product.tags (drives badges: "new", "bestseller")
  • product.selected_or_first_available_variant (price, compare_at_price, availability)
  • product.options_with_values (variant pickers)
  • product.metafields.custom.ingredients         → Ingredients accordion
  • product.metafields.custom.feeding_guidelines  → Feeding accordion
  • product.metafields.custom.shipping_info       → Shipping & returns accordion
  • product.metafields.custom.faq                 → FAQ accordion
  • product.metafields.custom.usage               → How to use accordion
  • product.metafields.reviews.rating             → star rating summary
  • product.metafields.reviews.count              → review count
  • product.metafields.reviews.rating_breakdown   → percentage by star rating (JSON)

  If a metafield is blank/missing, that accordion row simply doesn't render.
  No manual block entry needed per product.
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign discount_percent = 0 -%}
{%- if current_variant.compare_at_price > current_variant.price -%}
  {%- assign discount_percent = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round -%}
{%- endif -%}

{%- assign review_rating = product.metafields.reviews.rating.value | default: section.settings.default_rating -%}
{%- assign review_count = product.metafields.reviews.count.value | default: 0 -%}

{% comment %} Breadcrumb strip — dynamic from collection/product {% endcomment %}
<div class="paws-breadcrumb-strip">
  <div class="paws-wrap">
    <div class="paws-breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="m9 18 6-6-6-6"/></svg>
      <a href="{{ routes.all_products_collection_url }}">Shop</a>
      {% if product.collections.first %}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="m9 18 6-6-6-6"/></svg>
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
      {% endif %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="m9 18 6-6-6-6"/></svg>
      <span>{{ product.title }}</span>
    </div>
  </div>
</div>

<section class="paws-pdp-section" style="padding-top: 3rem;">
  <div class="paws-wrap">
    <div class="paws-pdp-layout">

      {% comment %} Gallery — uses product.media (not one image) {% endcomment %}
      <div class="paws-pdp-gallery">
        <div class="paws-gallery-main">
          {%- liquid
            if product.tags contains 'bestseller'
              assign pill_label = 'Bestseller'
            elsif product.tags contains 'new'
              assign pill_label = 'New'
            elsif product.tags contains 'vet-pick' or product.tags contains 'vet_pick'
              assign pill_label = 'Vet Pick'
            elsif discount_percent > 0
              assign pill_label = '-' | append: discount_percent | append: '%'
            endif
          -%}
          {%- if pill_label != blank -%}
            <span class="paws-gallery-pill">{{ pill_label }}</span>
          {%- endif -%}

          {%- if product.featured_media -%}
            <img
              id="pawsGalleryMain-{{ section.id }}"
              src="{{ product.featured_media | image_url: width: 1200 }}"
              alt="{{ product.featured_media.alt | default: product.title }}"
              loading="eager"
              width="1200"
              height="1200"
            >
          {%- else -%}
            <div style="width: 100%; aspect-ratio: 1; background: var(--paws-cream-deep); display: grid; place-items: center; color: var(--paws-ink); font-family: var(--paws-font-head); font-weight: 700;">
              No product image
            </div>
          {%- endif -%}
        </div>
        {% if product.media.size > 1 %}
          <div class="paws-gallery-thumbs">
            {% for media in product.media limit: 8 %}
              <button class="paws-thumb{% if forloop.first %} active{% endif %}" type="button" data-src="{{ media | image_url: width: 1200 }}" aria-label="View image {{ forloop.index }}">
                {{ media | image_url: width: 300 | image_tag: loading: 'lazy', alt: media.alt | default: product.title }}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      {% comment %} Info column — everything pulled from product {% endcomment %}
      <div class="paws-pdp-info">
        <div class="paws-product-meta" style="margin-bottom: 0.5rem;">
          {{ product.type | default: product.vendor }}{% if product.type != blank and product.vendor != blank %} · {{ product.vendor }}{% endif %}
        </div>
        <h1>{{ product.title }}</h1>

        {% if review_count != 0 or section.settings.show_default_rating %}
          <div class="paws-pdp-rating">
            <span class="stars">★★★★★</span>
            <strong>{{ review_rating }}</strong>
            {% if review_count != 0 %}
              <span>·</span>
              <a href="#paws-reviews">{{ review_count }} reviews</a>
            {% endif %}
          </div>
        {% endif %}

        <div class="paws-pdp-price">
          {% if current_variant.compare_at_price > current_variant.price %}
            <del>{{ current_variant.compare_at_price | money }}</del>
          {% endif %}
          {{ current_variant.price | money }}
          {% if discount_percent > 0 %}
            <span class="paws-pdp-save">Save {{ discount_percent }}%</span>
          {% endif %}
        </div>

        {% comment %} Product description — direct from product.description {% endcomment %}
        {% if product.description != blank %}
          <div class="paws-pdp-description rte">{{ product.description }}</div>
        {% endif %}

        {% comment %} Variant picker — dynamic from product.options_with_values {% endcomment %}
        {% unless product.has_only_default_variant %}
          <div class="paws-pdp-form-wrap">
            {% form 'product', product, id: 'paws-product-form-' | append: section.id, class: 'paws-pdp-form', novalidate: 'novalidate' %}
              {% for option in product.options_with_values %}
                <div class="paws-option-group paws-opt-group" data-option-index="{{ forloop.index0 }}">
                  <label>{{ option.name }}: <strong data-paws-selected-value>{{ option.selected_value }}</strong></label>
                  <div class="paws-option-buttons">
                    {% for value in option.values %}
                      <button
                        type="button"
                        class="paws-opt{% if value == option.selected_value %} active{% endif %}"
                        data-option-value="{{ value | escape }}"
                      >{{ value }}</button>
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}

              {% comment %} Hidden ID input, updated by JS when variant changes {% endcomment %}
              <input type="hidden" name="id" value="{{ current_variant.id }}" data-paws-variant-id>

              <div class="paws-pdp-actions">
                <div class="paws-pdp-qty paws-qty-wrap">
                  <button type="button" data-paws-qty-minus aria-label="Decrease quantity">−</button>
                  <span data-paws-qty-display class="paws-qty-display">1</span>
                  <button type="button" data-paws-qty-plus aria-label="Increase quantity">+</button>
                </div>
                <input type="hidden" name="quantity" value="1" data-paws-qty-input>
                <button
                  type="submit"
                  class="paws-btn paws-btn--coral paws-btn--lg"
                  data-paws-add-to-cart
                  {% unless current_variant.available %}disabled{% endunless %}
                >
                  <span data-paws-atc-label>
                    {% if current_variant.available %}
                      Add to cart · {{ current_variant.price | money }}
                    {% else %}
                      Sold out
                    {% endif %}
                  </span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/></svg>
                </button>
              </div>

              {% comment %} Variant data for JS to swap prices on variant select {% endcomment %}
              <script type="application/json" data-paws-variants>
                {{- product.variants | json -}}
              </script>
            {% endform %}
          </div>
        {% else %}
          {% form 'product', product, id: 'paws-product-form-' | append: section.id, class: 'paws-pdp-form' %}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
            <div class="paws-pdp-actions">
              <div class="paws-pdp-qty paws-qty-wrap">
                <button type="button" data-paws-qty-minus>−</button>
                <span data-paws-qty-display class="paws-qty-display">1</span>
                <button type="button" data-paws-qty-plus>+</button>
              </div>
              <input type="hidden" name="quantity" value="1" data-paws-qty-input>
              <button type="submit" class="paws-btn paws-btn--coral paws-btn--lg" data-paws-add-to-cart {% unless current_variant.available %}disabled{% endunless %}>
                {% if current_variant.available %}Add to cart · {{ current_variant.price | money }}{% else %}Sold out{% endif %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/></svg>
              </button>
            </div>
          {% endform %}
        {% endunless %}

        {% comment %} Perks strip — SITE-WIDE blocks set in theme editor (brand promises) {% endcomment %}
        {%- assign perk_blocks = section.blocks | where: 'type', 'perk' -%}
        {% if perk_blocks.size > 0 %}
          <div class="paws-pdp-perks">
            {% for block in perk_blocks %}
              <div class="paws-perk" {{ block.shopify_attributes }}>
                {% case block.settings.icon %}
                  {% when 'truck' %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><rect x="2" y="7" width="20" height="10" rx="2"/><path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2"/></svg>
                  {% when 'check' %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                  {% when 'clock' %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                  {% when 'heart' %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                {% endcase %}
                <span>{{ block.settings.text }}</span>
              </div>
            {% endfor %}
          </div>
        {% endif %}

        {% comment %} Accordion — PRODUCT METAFIELDS drive rows. No manual entry per product. {% endcomment %}
        {%- liquid
          assign has_ingredients = false
          assign has_feeding = false
          assign has_usage = false
          assign has_shipping = false
          assign has_faq = false
          if product.metafields.custom.ingredients.value != blank
            assign has_ingredients = true
          endif
          if product.metafields.custom.feeding_guidelines.value != blank
            assign has_feeding = true
          endif
          if product.metafields.custom.usage.value != blank
            assign has_usage = true
          endif
          if product.metafields.custom.shipping_info.value != blank or section.settings.default_shipping_info != blank
            assign has_shipping = true
          endif
          if product.metafields.custom.faq.value != blank
            assign has_faq = true
          endif

          assign any_accordion = false
          if has_ingredients or has_feeding or has_usage or has_shipping or has_faq
            assign any_accordion = true
          endif
        -%}

        {% if any_accordion %}
          <div class="paws-pdp-accordion paws-acc-list">
            {% if has_ingredients %}
              <div class="paws-acc-item open">
                <button class="paws-acc-header paws-acc-trigger" type="button" aria-expanded="true">
                  Ingredients
                  <span class="paws-acc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></span>
                </button>
                <div class="paws-acc-body"><div class="rte">{{ product.metafields.custom.ingredients.value }}</div></div>
              </div>
            {% endif %}
            {% if has_feeding %}
              <div class="paws-acc-item">
                <button class="paws-acc-header paws-acc-trigger" type="button" aria-expanded="false">
                  Feeding guidelines
                  <span class="paws-acc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></span>
                </button>
                <div class="paws-acc-body"><div class="rte">{{ product.metafields.custom.feeding_guidelines.value }}</div></div>
              </div>
            {% endif %}
            {% if has_usage %}
              <div class="paws-acc-item">
                <button class="paws-acc-header paws-acc-trigger" type="button" aria-expanded="false">
                  How to use
                  <span class="paws-acc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></span>
                </button>
                <div class="paws-acc-body"><div class="rte">{{ product.metafields.custom.usage.value }}</div></div>
              </div>
            {% endif %}
            {% if has_shipping %}
              <div class="paws-acc-item">
                <button class="paws-acc-header paws-acc-trigger" type="button" aria-expanded="false">
                  Shipping & returns
                  <span class="paws-acc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></span>
                </button>
                <div class="paws-acc-body">
                  <div class="rte">
                    {% if product.metafields.custom.shipping_info.value != blank %}
                      {{ product.metafields.custom.shipping_info.value }}
                    {% else %}
                      {{ section.settings.default_shipping_info }}
                    {% endif %}
                  </div>
                </div>
              </div>
            {% endif %}
            {% if has_faq %}
              <div class="paws-acc-item">
                <button class="paws-acc-header paws-acc-trigger" type="button" aria-expanded="false">
                  FAQ
                  <span class="paws-acc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></span>
                </button>
                <div class="paws-acc-body"><div class="rte">{{ product.metafields.custom.faq.value }}</div></div>
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% comment %} Reviews — only rendered if product has review data via metafields {% endcomment %}
{%- assign rating_breakdown = product.metafields.reviews.rating_breakdown.value -%}
{% if review_count != 0 or section.settings.show_reviews_placeholder %}
  <section class="paws-reviews-section" id="paws-reviews">
    <div class="paws-wrap">
      <div class="paws-section-head paws-reveal-up">
        <div>
          <span class="paws-eyebrow"><span>⭐</span> tail-wagging reviews</span>
          <h2>What the pack is saying</h2>
        </div>
        {% if section.settings.review_button_url != blank %}
          <a href="{{ section.settings.review_button_url }}" class="paws-btn paws-btn--coral">Write a review</a>
        {% endif %}
      </div>

      <div class="paws-reviews-grid">
        <div class="paws-review-summary">
          <div class="paws-big-rating">{{ review_rating }}</div>
          <div class="stars">★★★★★</div>
          <div class="paws-review-count">
            {% if review_count > 0 %}Based on {{ review_count }} reviews{% else %}Be the first to review{% endif %}
          </div>
          {% if rating_breakdown %}
            <div class="paws-review-bars">
              {% for i in (1..5) reversed %}
                {%- assign star_key = i | append: '_star' -%}
                {%- assign percent = rating_breakdown[star_key] | default: 0 -%}
                <div class="paws-review-bar-row"><span>{{ i }}★</span><div class="paws-review-bar-track"><div class="paws-review-bar-fill" style="width: {{ percent }}%"></div></div><span>{{ percent }}%</span></div>
              {% endfor %}
            </div>
          {% endif %}
        </div>

        <div class="paws-review-list">
          {% comment %} Pull review list from product.metafields.reviews.list (JSON array) {% endcomment %}
          {%- assign review_list = product.metafields.reviews.list.value -%}
          {% if review_list %}
            {% for review in review_list %}
              <div class="paws-review">
                <div class="paws-review-head">
                  <div class="paws-reviewer">
                    {% if review.avatar %}<img src="{{ review.avatar }}" alt="{{ review.name }}" loading="lazy">{% endif %}
                    <div><strong>{{ review.name }}</strong><span>{{ review.meta }}</span></div>
                  </div>
                  <span class="stars">{% if review.stars == 4 %}★★★★☆{% else %}★★★★★{% endif %}</span>
                </div>
                {% if review.title %}<h4>{{ review.title }}</h4>{% endif %}
                <p>{{ review.body }}</p>
              </div>
            {% endfor %}
          {% else %}
            <div class="paws-review" style="text-align: center; padding: 3rem 2rem;">
              <p style="opacity: 0.7;">Reviews will appear here once customers leave them.</p>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Paws PDP",
  "tag": "section",
  "class": "paws-section-pdp",
  "settings": [
    { "type": "header", "content": "Product data (per-product, set via metafields)" },
    { "type": "paragraph", "content": "All per-product content (ingredients, feeding guidelines, reviews, etc.) is pulled from product metafields. Configure them in Shopify admin → Settings → Custom data → Products. Namespace: 'custom'. Keys: ingredients, feeding_guidelines, usage, shipping_info, faq. For reviews: namespace 'reviews', keys: rating, count, rating_breakdown, list." },

    { "type": "header", "content": "Reviews placeholder" },
    { "type": "text", "id": "default_rating", "label": "Default rating (if no reviews metafield)", "default": "4.9" },
    { "type": "checkbox", "id": "show_default_rating", "label": "Show rating even with 0 reviews", "default": true },
    { "type": "checkbox", "id": "show_reviews_placeholder", "label": "Always show reviews section (even if 0)", "default": true },
    { "type": "url", "id": "review_button_url", "label": "'Write a review' button URL" },

    { "type": "header", "content": "Site-wide defaults" },
    { "type": "richtext", "id": "default_shipping_info", "label": "Default shipping & returns copy (used if product has no shipping_info metafield)",
      "default": "<p>Free US shipping on $50+. Ships within 24 hours. Return unopened within 30 days for a full refund.</p>" }
  ],
  "blocks": [
    {
      "type": "perk",
      "name": "Site-wide perk",
      "limit": 6,
      "settings": [
        { "type": "paragraph", "content": "Perks are shown on every product page (brand promises like free shipping). These are not per-product." },
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          { "value": "truck", "label": "Truck (shipping)" },
          { "value": "check", "label": "Checkmark (guarantee)" },
          { "value": "clock", "label": "Clock (ships fast)" },
          { "value": "heart", "label": "Heart (cruelty-free)" }
        ], "default": "truck" },
        { "type": "text", "id": "text", "label": "Text", "default": "Free shipping over $50" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Paws PDP",
      "blocks": [
        { "type": "perk", "settings": { "icon": "truck", "text": "Free shipping over $50" } },
        { "type": "perk", "settings": { "icon": "check", "text": "30-day money back" } },
        { "type": "perk", "settings": { "icon": "clock", "text": "Ships in 24 hrs" } },
        { "type": "perk", "settings": { "icon": "heart", "text": "Cruelty-free, always" } }
      ]
    }
  ]
}
{% endschema %}
